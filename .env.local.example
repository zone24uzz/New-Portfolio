# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Password for /admin login page
NEXT_PUBLIC_ADMIN_PASSWORD=your-secure-password-here

# Token sent in x-admin-token header to protect API routes
# Must match NEXT_PUBLIC_ADMIN_TOKEN on client and ANALYTICS_ADMIN_TOKEN on server
NEXT_PUBLIC_ADMIN_TOKEN=your-secret-token-here
ANALYTICS_ADMIN_TOKEN=your-secret-token-here
